# SQLite (local dev)
DATABASE_URL="file:./prisma/dev.db"

# Auth.js (NextAuth) v5
# Generate one with: openssl rand -base64 32
AUTH_SECRET="change-me-in-production"
AUTH_TRUST_HOST="true"

