// Prisma schema for PersonalPlanerMVP
// Single-tenant Swiss SME planning + time-account web app.

generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

// ---------- Enums ----------

enum Role {
  ADMIN
  EMPLOYEE
}

enum WeekStatus {
  DRAFT
  PUBLISHED
  CLOSED
}

enum PlanEntryKind {
  SHIFT
  ONE_TIME_SHIFT
  ABSENCE
  VFT
}

enum AbsenceType {
  VACATION
  SICK
  ACCIDENT
  FREE_REQUESTED
  UNPAID
  TZT
  PARENTAL_CARE
  MILITARY_SERVICE
  CIVIL_PROTECTION_SERVICE
  CIVIL_SERVICE
  HOLIDAY_AUTO
}

enum RequestType {
  VACATION
  FREE_REQUESTED
  TZT
  FREE_DAY
  PARENTAL_CARE
}

enum RequestStatus {
  OPEN
  APPROVED
  REJECTED
}

enum PrivacyRequestType {
  EXPORT
  ERASURE
}

enum PrivacyRequestStatus {
  OPEN
  APPROVED
  REJECTED
  COMPLETED
}

enum AccountType {
  ZEITSALDO
  FERIEN
  UEZ
  TZT
  SONNTAG_FEIERTAG_KOMPENSATION
  PARENTAL_CARE
}

enum AccountUnit {
  MINUTES
  DAYS
}

enum BookingType {
  OPENING
  AUTO_WEEKLY
  FREE_REQUESTED
  MANUAL_CREDIT
  MANUAL_DEBIT
  CORRECTION
  CARRYOVER
}

/// TZT accounting variant (Spec: Modell 1 = Tageskontingent, Modell 2 = Sollzeit-Reduktion).
enum TztModel {
  DAILY_QUOTA
  TARGET_REDUCTION
}

enum ErtCaseStatus {
  OPEN
  FULFILLED
  OVERDUE
}

// ---------- Core entities ----------

model User {
  id           String     @id @default(cuid())
  tenantId     String     @default("default")
  tenant       Tenant     @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  email        String
  passwordHash String
  role         Role
  isActive     Boolean    @default(true)
  employee     Employee?
  bookings     Booking[]  @relation("BookingCreatedBy")
  privacyDecisions PrivacyRequest[] @relation("PrivacyRequestDecidedBy")
  auditLogs    AuditLog[]
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@unique([tenantId, email])
}

model Tenant {
  id            String              @id @default(cuid())
  name          String
  slug          String              @unique
  createdAt     DateTime            @default(now())
  deletedAt     DateTime?
  archivedUntil DateTime?
  users         User[]
  employees     Employee[]
  locations     Location[]
  serviceTemplates ServiceTemplate[]
  weeks         Week[]
  holidays      Holiday[]
  bookings      Booking[]
  absenceRequests AbsenceRequest[]
  accountBalances AccountBalance[]
  privacyRequests PrivacyRequest[]
  ertCases      ErtCase[]
  publishedSnapshots PublishedSnapshot[]
}

model Location {
  id                 String     @id @default(cuid())
  tenantId           String     @default("default")
  tenant             Tenant     @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  name               String
  holidayRegionCode  String
  employees          Employee[]
  holidays           Holiday[]
  deletedAt          DateTime?
  archivedUntil      DateTime?
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt
}

model Employee {
  id                   String            @id @default(cuid())
  tenantId             String            @default("default")
  tenant               Tenant            @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  userId               String            @unique
  user                 User              @relation(fields: [userId], references: [id], onDelete: Restrict)
  firstName            String
  lastName             String
  roleLabel            String?           // e.g. "Verkauf", "Backoffice"
  pensum               Int               // 0-100
  entryDate            DateTime
  exitDate             DateTime?
  locationId           String
  location             Location          @relation(fields: [locationId], references: [id])
  vacationDaysPerYear  Float             @default(25)
  weeklyTargetMinutes  Int               @default(2520) // 42h * 60
  hazMinutesPerWeek    Int               @default(2700) // 45h * 60
  tztModel             TztModel          @default(DAILY_QUOTA)
  isActive             Boolean           @default(true)
  deletedAt            DateTime?
  archivedUntil        DateTime?
  planEntries          PlanEntry[]
  absenceRequests      AbsenceRequest[]
  privacyRequests      PrivacyRequest[]
  accountBalances      AccountBalance[]
  bookings             Booking[]
  ertCases             ErtCase[]
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt
}

model PrivacyRequest {
  id          String               @id @default(cuid())
  tenantId    String               @default("default")
  tenant      Tenant               @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  employeeId  String
  employee    Employee             @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  type        PrivacyRequestType
  status      PrivacyRequestStatus @default(OPEN)
  note        String?
  decidedById String?
  decidedBy   User?                @relation("PrivacyRequestDecidedBy", fields: [decidedById], references: [id], onDelete: SetNull)
  decidedAt   DateTime?
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt

  @@index([employeeId, createdAt])
  @@index([status, type])
}

model Holiday {
  id          String   @id @default(cuid())
  tenantId    String   @default("default")
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  date        DateTime
  name        String
  locationId  String
  location    Location @relation(fields: [locationId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())

  @@unique([locationId, date])
}

model ServiceTemplate {
  id             String      @id @default(cuid())
  tenantId       String      @default("default")
  tenant         Tenant      @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  name           String
  code           String
  startTime      String      // "07:00"
  endTime        String      // "15:30"
  breakMinutes   Int         @default(30)
  comment        String?
  defaultDays    Int?        // bitmask: Mon=1, Tue=2, ..., Sun=64
  requiredCount  Int?
  isActive       Boolean     @default(true)
  planEntries    PlanEntry[]
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  @@unique([tenantId, code])
}

model Week {
  id            String              @id @default(cuid())
  tenantId      String              @default("default")
  tenant        Tenant              @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  year          Int
  weekNumber    Int
  status        WeekStatus          @default(DRAFT)
  publishedAt   DateTime?
  closedAt      DateTime?
  deletedAt     DateTime?
  archivedUntil DateTime?
  planEntries   PlanEntry[]
  snapshots     PublishedSnapshot[]
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  @@unique([tenantId, year, weekNumber])
}

model PlanEntry {
  id                  String           @id @default(cuid())
  weekId              String
  week                Week             @relation(fields: [weekId], references: [id], onDelete: Cascade)
  employeeId          String
  employee            Employee         @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  date                DateTime
  kind                PlanEntryKind
  serviceTemplateId   String?
  serviceTemplate     ServiceTemplate? @relation(fields: [serviceTemplateId], references: [id])
  oneTimeStart        String?          // "07:00"
  oneTimeEnd          String?          // "15:30"
  oneTimeBreakMinutes Int?
  oneTimeLabel        String?
  absenceType         AbsenceType?
  plannedMinutes      Int              @default(0)
  comment             String?
  deletedAt           DateTime?
  archivedUntil       DateTime?
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt

  @@index([weekId, employeeId, date])
}

model PublishedSnapshot {
  id           String   @id @default(cuid())
  tenantId     String   @default("default")
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  weekId       String
  week         Week     @relation(fields: [weekId], references: [id], onDelete: Cascade)
  snapshotJson String
  publishedAt  DateTime @default(now())
}

model AbsenceRequest {
  id            String         @id @default(cuid())
  tenantId      String         @default("default")
  tenant        Tenant         @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  employeeId    String
  employee      Employee       @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  type          RequestType
  startDate     DateTime
  endDate       DateTime
  status        RequestStatus  @default(OPEN)
  comment       String?
  decidedAt     DateTime?
  decidedById   String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

model AccountBalance {
  id            String      @id @default(cuid())
  tenantId      String      @default("default")
  tenant        Tenant      @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  employeeId    String
  employee      Employee    @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  accountType   AccountType
  year          Int
  openingValue  Float       @default(0)
  currentValue  Float       @default(0)
  unit          AccountUnit
  updatedAt     DateTime    @updatedAt

  @@unique([employeeId, accountType, year])
}

model Booking {
  id              String       @id @default(cuid())
  tenantId        String       @default("default")
  tenant          Tenant       @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  employeeId      String
  employee        Employee     @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  accountType     AccountType
  date            DateTime
  value           Float        // signed, in account unit
  bookingType     BookingType
  comment         String?
  createdByUserId String
  createdByUser   User         @relation("BookingCreatedBy", fields: [createdByUserId], references: [id])
  createdAt       DateTime     @default(now())

  @@index([employeeId, accountType, date])
}

model AuditLog {
  id         String   @id @default(cuid())
  tenantId   String
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  action     String   // CREATE, UPDATE, DELETE, PUBLISH, CLOSE, ...
  entity     String   // Employee, PlanEntry, Booking, ...
  entityId   String?
  oldValue   String?
  newValue   String?
  comment    String?
  createdAt  DateTime @default(now())

  @@index([entity, entityId])
  @@index([tenantId, createdAt])
  @@index([createdAt])
}

model ErtCase {
  id               String        @id @default(cuid())
  tenantId         String        @default("default")
  tenant           Tenant        @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  employeeId       String
  employee         Employee      @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  triggerDate      DateTime
  holidayWorkMinutes Int
  status           ErtCaseStatus @default(OPEN)
  dueAt            DateTime
  fulfilledAt      DateTime?
  note             String?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  @@unique([employeeId, triggerDate])
  @@index([employeeId, status, dueAt])
}
